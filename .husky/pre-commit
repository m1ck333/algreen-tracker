#!/usr/bin/env sh
# Run our static checks BEFORE commit so regressions are caught at the
# keyboard, not in QA. Ordered fastest-to-slowest so quick failures
# (i18n key missing, brand leak) abort before TypeScript/ESLint spin up.
# Total budget ~5-8s on a warm machine — anything slower starts losing
# the dev to --no-verify.

# Merge conflict marker check — accidentally committing leftover conflict
# text breaks the build silently for everyone else. Five-line check.
if git diff --cached -U0 | grep -E '^\+(<{7}|={7}|>{7})' >/dev/null; then
  echo "✗ Merge conflict markers in staged content. Resolve before committing."
  exit 1
fi

echo "→ Checking i18n keys…"
node scripts/check-i18n-keys.mjs || exit 1

echo "→ Checking locale placeholders…"
node scripts/check-locale-placeholders.mjs || exit 1

echo "→ Checking brand leaks…"
node scripts/check-brand-leaks.mjs || exit 1

echo "→ Checking hardcoded colors…"
node scripts/check-hardcoded-colors.mjs || exit 1

echo "→ Checking file sizes…"
node scripts/check-file-size.mjs || exit 1

echo "→ ESLint on staged files…"
pnpm exec lint-staged || exit 1

echo "→ TypeScript check…"
pnpm typecheck || exit 1
